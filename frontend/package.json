{
  "name": "aegisquantum-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .ts src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "test:kem": "vitest run src/crypto/__tests__/kem.test.ts",
    "test:kem:cov": "npm run test -- run src/crypto/__tests__/kem.test.ts --coverage.enabled --coverage.include='src/crypto/kem.ts' --coverage.reporter='lcov' --coverage.reporter='text'",
    "test:dsa": "vitest run src/crypto/__tests__/dsa.test.ts",
    "test:hkdf": "vitest run src/crypto/__tests__/hkdf.test.ts",
    "test:aes": "vitest run src/crypto/__tests__/aes-gcm.test.ts",
    "test:argon2": "vitest run src/crypto/__tests__/argon2.test.ts",
    "test:ratchet-state": "vitest run src/crypto/__tests__/ratchet-state.test.ts",
    "test:crypto": "vitest run src/crypto/__tests__/",
    "test:crypto:cov": "npm run test -- run src/crypto/__tests__/ --coverage.enabled --coverage.include='src/crypto/*.ts' --coverage.reporter='lcov' --coverage.reporter='text'",
    "test:auth": "vitest run src/services/__tests__/auth.test.ts",
    "test:key-store": "vitest run src/services/__tests__/key-store.test.ts",
    "test:key-registry": "vitest run src/services/__tests__/key-registry.test.ts",
    "test:messaging": "vitest run src/services/__tests__/messaging.test.ts",
    "test:db": "vitest run src/services/__tests__/db.test.ts",
    "test:services": "vitest run src/services/__tests__/",
    "test:services:cov": "npm run test -- run src/services/__tests__/ --coverage.enabled --coverage.include='src/services/*.ts' --coverage.reporter='lcov' --coverage.reporter='text'",
    "test:all": "vitest run",
    "test:all:cov": "vitest run --coverage",
    "test:kpi": "vitest run -t '\\[KPI\\]'",
    "test:sec": "vitest run -t '\\[SEC\\]|\\[PENTEST\\]|\\[SIDE-CHANNEL\\]|\\[SESSION\\]'",
    "test:pentest": "vitest run -t '\\[PENTEST\\]'",
    "test:pentest:crypto": "vitest run src/crypto/__tests__/ -t '\\[PENTEST\\]'",
    "test:pentest:services": "vitest run src/services/__tests__/ -t '\\[PENTEST\\]|\\[SEC\\]|\\[SESSION\\]'",
    "test:double-ratchet": "vitest run src/crypto/__tests__/double-ratchet.test.ts "
  },
  "dependencies": {
    "@openforge-sh/liboqs": "latest",
    "argon2-browser": "^1.18.0",
    "firebase": "^10.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.1.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
