rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PUBLIC KEYS ──────────────────────────────────────────────────────────
    match /publicKeys/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── USERS (salt Argon2) ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── PROVISIONED (mustChangePassword) ────────────────────────────────────
    match /provisioned/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create, delete: if false;
    }

    // ── CONVERSATIONS ────────────────────────────────────────────────────────
    match /conversations/{convId} {
      // Lecture : autorisée si le doc existe et que l'user est participant
      // OU si le doc n'existe pas encore (resource == null) et que l'user est authentifié
      // → nécessaire pour le getDoc() dans getOrCreateConversation()
      allow read: if request.auth != null
                  && (resource == null
                      || request.auth.uid in resource.data.participants);

      // Création : l'auteur doit être dans les participants
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;

      // Mise à jour : participant du document existant
      allow update: if request.auth != null
                    && resource != null
                    && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // ── MESSAGES (sous-collection) ──────────────────────────────────────
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.senderUid;
        allow update, delete: if false;
      }
    }

    // ── CATCH-ALL ────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
