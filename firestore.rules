rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PUBLIC KEYS ──────────────────────────────────────────────────────────
    match /publicKeys/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── USERS (salt Argon2) ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── PROVISIONED (mustChangePassword) ────────────────────────────────────
    match /provisioned/{userId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create, delete: if false;
    }

    // ── CONVERSATIONS ────────────────────────────────────────────────────────
    match /conversations/{convId} {
      // Lecture : autorisée si le doc existe et que l'user est participant
      // OU si le doc n'existe pas encore (resource == null) et que l'user est authentifié
      // → nécessaire pour le getDoc() dans getOrCreateConversation()
      allow read: if request.auth != null
                  && (resource == null
                      || request.auth.uid in resource.data.participants);

      // Création : l'auteur doit être dans les participants
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;

      // Mise à jour : participant du document existant
      allow update: if request.auth != null
                    && resource != null
                    && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // ── MESSAGES (sous-collection) ──────────────────────────────────────
      match /messages/{messageId} {
        // Lecture : participant de la conversation
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        // Création : l'envoyeur doit être participant ET déclarer son propre uid
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.senderUid
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;

        // Mise à jour : UNIQUEMENT pour ajouter son uid dans readBy (statut de lecture)
        // On vérifie :
        //   1. L'user est participant de la conversation
        //   2. Seul le champ readBy est modifié (pas de mutation du ciphertext, etc.)
        //   3. L'user ne peut ajouter QUE son propre uid dans readBy
        allow update: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
                      && request.auth.uid in request.resource.data.readBy;

        allow delete: if false;
      }

      // ── TYPING (sous-collection) ──────────────────────────────────────────
      match /typing/{uid} {
        // Lecture : l'auth.uid doit être l'un des deux segments du convId.
        // convId = [uid1, uid2].sort().join("_") — on vérifie que auth.uid
        // apparaît dans convId sans cross-document get().
        //
        // Pourquoi pas get() ici comme pour /messages ?
        // Un cross-document get() en règle de sécurité nécessite un round-trip
        // serveur Firestore et rate silencieusement en prod si le doc parent
        // n'est pas encore dans le cache Firebase au moment où onSnapshot s'établit.
        // En dev le cache local masque ce timing, d'où le bug "typing OK en dev,
        // cassé en prod". La vérification via convId.matches() est instantanée
        // et ne dépend d'aucun état externe.
        allow read: if request.auth != null
                    && convId.matches('.*' + request.auth.uid + '.*');

        // Écriture / suppression : uniquement son propre doc typing,
        // et l'uid doit être dans le convId (même logique que read).
        allow write: if request.auth != null
                     && request.auth.uid == uid
                     && convId.matches('.*' + request.auth.uid + '.*');
      }
    }

    // ── CATCH-ALL ────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
